{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jacaudi/github-actions/docs/schemas/meta-code-scan.json",
  "title": "code-scan block metadata",
  "description": "Artifact emitted by the code-scan lego block. Contains the raw Trivy filesystem scan output (SchemaVersion 2) covering vulnerability, secret, and misconfiguration scanners.",
  "type": "object",
  "required": ["SchemaVersion", "ArtifactName", "ArtifactType", "Results"],
  "properties": {
    "SchemaVersion": {
      "type": "integer",
      "description": "Trivy output schema version. Always 2.",
      "const": 2
    },
    "CreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the scan was run (ISO 8601)."
    },
    "ArtifactName": {
      "type": "string",
      "description": "Scanned target path. Typically '.' for the repository root."
    },
    "ArtifactType": {
      "type": "string",
      "description": "Type of scanned artifact.",
      "const": "filesystem"
    },
    "Results": {
      "type": "array",
      "description": "Scan results grouped by target file or package manifest.",
      "items": {
        "$ref": "#/$defs/Result"
      }
    }
  },
  "$defs": {
    "Result": {
      "type": "object",
      "required": ["Target", "Class", "Type"],
      "properties": {
        "Target": {
          "type": "string",
          "description": "The file or package manifest that was scanned (e.g. 'go.sum', 'Dockerfile')."
        },
        "Class": {
          "type": "string",
          "description": "Result class: os-pkgs, lang-pkgs, config, secret.",
          "enum": ["os-pkgs", "lang-pkgs", "config", "secret", "license"]
        },
        "Type": {
          "type": "string",
          "description": "Package ecosystem or config type (e.g. 'gomod', 'pip', 'dockerfile')."
        },
        "Vulnerabilities": {
          "type": "array",
          "description": "CVEs found in package manifests or lockfiles.",
          "items": { "$ref": "#/$defs/Vulnerability" }
        },
        "Misconfigurations": {
          "type": "array",
          "description": "IaC misconfigurations (Dockerfile, Kubernetes manifests, Terraform).",
          "items": { "$ref": "#/$defs/Misconfiguration" }
        },
        "Secrets": {
          "type": "array",
          "description": "Secrets or credentials detected in source files.",
          "items": { "$ref": "#/$defs/Secret" }
        }
      }
    },
    "Vulnerability": {
      "type": "object",
      "required": ["VulnerabilityID", "PkgName", "InstalledVersion", "Severity"],
      "properties": {
        "VulnerabilityID": { "type": "string", "description": "CVE identifier (e.g. CVE-2024-1234)." },
        "PkgName":         { "type": "string", "description": "Affected package name." },
        "InstalledVersion":{ "type": "string", "description": "Installed version of the package." },
        "FixedVersion":    { "type": "string", "description": "Version where the CVE is fixed, if available." },
        "Severity":        { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","UNKNOWN"] },
        "Title":           { "type": "string" },
        "Description":     { "type": "string" },
        "PrimaryURL":      { "type": "string", "format": "uri" },
        "Status":          { "type": "string", "enum": ["fixed","affected","will_not_fix","end_of_life","under_investigation"] }
      }
    },
    "Misconfiguration": {
      "type": "object",
      "required": ["ID", "Title", "Severity", "Status"],
      "properties": {
        "Type":        { "type": "string", "description": "Check type (e.g. 'Dockerfile Security Check')." },
        "ID":          { "type": "string", "description": "Rule ID (e.g. DS002, AVD-DS-0002)." },
        "Title":       { "type": "string" },
        "Description": { "type": "string" },
        "Message":     { "type": "string", "description": "Human-readable failure message." },
        "Severity":    { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","UNKNOWN"] },
        "Status":      { "type": "string", "enum": ["FAIL","PASS","EXCEPTION"] },
        "Resolution":  { "type": "string" },
        "PrimaryURL":  { "type": "string", "format": "uri" }
      }
    },
    "Secret": {
      "type": "object",
      "required": ["RuleID", "Category", "Severity", "Title", "StartLine", "EndLine", "Match"],
      "properties": {
        "RuleID":    { "type": "string", "description": "Secret detection rule ID." },
        "Category":  { "type": "string", "description": "Secret category (e.g. 'aws-access-key-id', 'github-pat')." },
        "Severity":  { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","UNKNOWN"] },
        "Title":     { "type": "string" },
        "StartLine": { "type": "integer" },
        "EndLine":   { "type": "integer" },
        "Match":     { "type": "string", "description": "Redacted match string." }
      }
    }
  }
}
