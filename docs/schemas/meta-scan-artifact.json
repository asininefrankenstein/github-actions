{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jacaudi/github-actions/docs/schemas/meta-scan-artifact.json",
  "title": "scan-artifact block metadata",
  "description": "Artifact emitted by the scan-artifact (image-scan) building block. Contains the raw Trivy image scan output (SchemaVersion 2) covering vulnerability and secret scanners against a built container image.",
  "type": "object",
  "required": ["SchemaVersion", "ArtifactName", "ArtifactType", "Metadata", "Results"],
  "properties": {
    "SchemaVersion": {
      "type": "integer",
      "description": "Trivy output schema version. Always 2.",
      "const": 2
    },
    "CreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the scan was run (ISO 8601)."
    },
    "ArtifactName": {
      "type": "string",
      "description": "Scanned image reference (registry/name@sha256:... or tag)."
    },
    "ArtifactType": {
      "type": "string",
      "const": "container_image"
    },
    "Metadata": {
      "type": "object",
      "description": "Image metadata extracted during scan.",
      "properties": {
        "OS": {
          "type": "object",
          "properties": {
            "Family": { "type": "string", "description": "OS family (e.g. alpine, ubuntu, debian)." },
            "Name":   { "type": "string", "description": "OS version string." }
          }
        },
        "ImageID":     { "type": "string", "description": "Image ID (sha256:...)." },
        "RepoTags":    { "type": "array", "items": { "type": "string" } },
        "RepoDigests": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Results": {
      "type": "array",
      "description": "Scan results grouped by image layer or package manifest.",
      "items": {
        "type": "object",
        "required": ["Target", "Class", "Type"],
        "properties": {
          "Target": { "type": "string" },
          "Class":  { "type": "string", "enum": ["os-pkgs", "lang-pkgs", "secret"] },
          "Type":   { "type": "string" },
          "Vulnerabilities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["VulnerabilityID", "PkgName", "InstalledVersion", "Severity"],
              "properties": {
                "VulnerabilityID":  { "type": "string" },
                "PkgName":          { "type": "string" },
                "InstalledVersion": { "type": "string" },
                "FixedVersion":     { "type": "string" },
                "Severity":         { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","UNKNOWN"] },
                "Title":            { "type": "string" },
                "PrimaryURL":       { "type": "string", "format": "uri" },
                "Status":           { "type": "string" }
              }
            }
          },
          "Secrets": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["RuleID", "Category", "Severity", "Title"],
              "properties": {
                "RuleID":   { "type": "string" },
                "Category": { "type": "string" },
                "Severity": { "type": "string", "enum": ["CRITICAL","HIGH","MEDIUM","LOW","UNKNOWN"] },
                "Title":    { "type": "string" },
                "Match":    { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
